---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Contact — Jordan Goodson';
const description = 'Open to consulting engagements, AI integration projects, and conversations about what automation can do for your business.';
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta name="theme-color" content="#05070D">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Jordan Goodson">
  <meta name="twitter:card" content="summary">
  <meta property="og:title" content="Contact — Jordan Goodson">
  <meta property="og:description" content="Open to consulting engagements and AI integration projects.">
  <meta property="og:url" content="https://jordangoodson.com/contact">
</head>
<body>
  <Header />

  <section class="hero" style="padding: 3rem 2rem;">
    <div class="container">
      <h1>Get in Touch</h1>
      <p class="lead" style="color: var(--text-body); margin-top: 1rem;">
        Open to consulting engagements, AI integration projects, and conversations about what automation can do for your business.
      </p>
    </div>
  </section>

  <section style="padding: 4rem 2rem; background: var(--bg);">
    <div class="container">
      <div class="contact-form">
        <form id="contact-form" name="contact" method="POST" action="https://formspree.io/f/maqgaoyr">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" required></textarea>
          </div>
          <div class="form-group">
            <button type="submit">Send Message</button>
          </div>
        </form>
      </div>

      <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border);">
        <h2 style="text-align: center; margin-bottom: 2rem;">Connect Elsewhere</h2>
        <div style="display: flex; justify-content: center; gap: 3rem;">
          <a href="https://linkedin.com/in/jordangoodson-ai/" target="_blank" style="color: var(--accent); text-decoration: none; font-weight: 600;">LinkedIn</a>
          <a href="https://github.com/PicklesNgitz" target="_blank" style="color: var(--accent); text-decoration: none; font-weight: 600;">GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</body>
</html>
