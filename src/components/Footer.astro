<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>Jordan Goodson</h3>
        <p>AI Integration & Automation Engineer</p>
      </div>
      <div class="footer-section">
        <h4>Navigation</h4>
        <nav class="footer-nav">
          <a href="/">Bio</a>
          <a href="/skills">Skills</a>
          <a href="/projects">Projects</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
      <div class="footer-section">
        <h4>Connect</h4>
        <nav class="footer-nav">
          <a href="https://linkedin.com/in/jordangoodson-ai/" target="_blank">LinkedIn</a>
          <a href="https://github.com/PicklesNgitz" target="_blank">GitHub</a>
        </nav>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2025 Jordan Goodson. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-raised);
    border-top: 1px solid var(--border);
    padding: 3rem 2rem 1rem;
    margin-top: 4rem;
  }

  .footer .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .footer-section h3,
  .footer-section h4 {
    color: var(--text);
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  .footer-section p {
    color: var(--text-body);
    font-size: 0.9rem;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-nav a {
    color: var(--text-body);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
    text-align: center;
  }

  .footer-bottom p {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>
