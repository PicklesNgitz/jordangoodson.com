---
---

<header class="header">
  <div class="container">
    <a href="/" class="logo">Jordan Goodson</a>
    <nav class="nav">
      <a href="/">Bio</a>
      <a href="/skills">Skills</a>
      <a href="/projects">Projects</a>
      <a href="/skills#certifications">Certifications</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background: var(--bg-raised);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 2rem;
  }

  .logo {
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    font-size: 1.25rem;
  }

  .nav {
    display: flex;
    gap: 2rem;
  }

  .nav a {
    color: var(--text-body);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .nav a:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .header .container {
      padding: 0 1rem;
    }

    .nav {
      gap: 1rem;
    }

    .nav a {
      font-size: 0.85rem;
    }
  }
</style>
